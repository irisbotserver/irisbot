(e) { }\n}\n\nloadDatabase();\nsetInterval(saveDatabase, 10000);\n\nconst addLog = (text) => {\n    const time = new Date().toLocaleTimeString();\n    db.logs.push(`[${time}] ${text}`);\n    if (db.logs.length > 50) db.logs.shift();\n};\n\n// =======================================================\n// 🚀 INÍCIO DO BOT (LIMAX ENGINE)\n// =======================================================\nasync function startBot() {\n    console.log(\"\\x1b[36m[INICIANDO]\\x1b[0m Carregando credenciais...\");\n    const { state, saveCreds } = await useMultiFileAuthState(\"auth_iris\");\n\n    console.log(\"\\x1b[36m[INICIANDO]\\x1b[0m Buscando versão do WhatsApp...\");\n    const { version } = await fetchLatestBaileysVersion();\n    console.log(`\\x1b[32m[SISTEMA]\\x1b[0m Usando WA versão: ${version.join('.')}`);\n\n    const sock = makeWASocket({\n        version,\n        logger: P({ level: \"silent\" }),\n        printQRInTerminal: !usePairingCode,\n        auth: {\n            creds: state.creds,\n            keys: makeCacheableSignalKeyStore(state.keys, P({ level: \"silent\" })),\n        },\n        browser: [\"Ubuntu\", \"Chrome\", \"20.0.04\"],\n        markOnlineOnConnect: true,\n        defaultQueryTimeoutMs: undefined\n    });\n\n    console.log(\"\\x1b[33m[SISTEMA]\\x1b[0m Servidor Socket Inicializado.\");\n\n    sock.copyNForward = async (jid, message, forceForward = false, options = {}) => {\n        // ... (remaining copyNForward code stays same)\n        let vtype\n        if (options.readViewOnce) {\n            message.message = message.message && message.message.viewOnceMessageV2 && message.message.viewOnceMessageV2.message ? message.message.viewOnceMessageV2.message : (message.message && message.message.viewOnceMessage && message.message.viewOnceMessage.message ? message.message.viewOnceMessage.message : message.message)\n            vtype = Object.keys(message.message)[0]\n            delete message.message.viewOnceMessageV2\n            delete message.message[vtype].viewOnce\n            message.message = { ...message.message }\n        }\n        let type = Object.keys(message.message)[0]\n        let content = message.message[type]\n        if (type == 'viewOnceMessageV2') {\n            content = message.message.viewOnceMessageV2.message\n            type = Object.keys(content)[0]\n        }\n        let contextInfo = {}\n        if (type == 'extendedTextMessage') contextInfo = content.contextInfo\n        message.message[type].contextInfo = { ...contextInfo, ...options.contextInfo }\n        const waMessage = await Baileys.generateWAMessageFromContent(jid, message.message, { userJid: sock.user.id, ...options })\n        await sock.relayMessage(jid, waMessage.message, { messageId: waMessage.key.id })\n        return waMessage\n    }\n\n    sock.ev.on(\"creds.update\", saveCreds);\n\n    if (usePairingCode && !state.creds.registered) {\n        console.log(\"\\x1b[33m[SISTEMA]\\x1b[0m Gerando Código de Pareamento...\");\n        const cleanNumber = botNumber.replace(/\\D/g, '');\n        setTimeout(async () => {\n            try {\n                const code = await sock.requestPairingCode(cleanNumber);\n                const formattedCode = code?.match(/.{1,4}/g)?.join(\"-\") || code;\n                console.log(\"\\n\\x1b[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\x1b[0m\");\n                console.log(`\\x1b[1;33m📱 SEU CÓDIGO [${BOT_NAME}]: \\x1b[1;32m${formattedCode || \"NÃO GERADO\"}\\x1b[0m`);\n                console.log(\"\\x1b[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\x1b[0m\\n\");\n                addLog(`Pairing Code: ${formattedCode}`);\n            } catch (error) {\n                console.error(\"❌ Erro Pairing Code:\", error);\n                console.log(\"DICA: Verifique se o número do bot está correto e se você tem internet.\");\n            }\n        }, 3000);\n    }\n\n    sock.ev.on(\"connection.update\", async (update) => {\n        const { connection, lastDisconnect, qr } = update;\n\n        if (qr) console.log(\"\\x1b[33m[SISTEMA]\\x1b[0m QR Code gerado. Escaneie no WhatsApp.\");\n\n        if (connection === \"connecting\") {\n            console.log(\"\\x1b[33m[SISTEMA]\\x1b[0m Estabelecendo conexão...\");\n        }\n\n        if (connection === \"open\") {\n            console.log(\"\\n\\x1b[1;32m\" + \"=\".repeat(40));\n            console.log(`🟢 [ONLINE] ${BOT_NAME} CONECTADO!`);\n            console.log(\"=\".repeat(40) + \"\\x1b[0m\\n\");\n            addLog(\"Sistema Online\");\n            await sock.sendMessage(adminNumber, { text: `😈 *${BOT_NAME} ONLINE*` }).catch(() => { });\n        }\n\n        if (connection === \"close\") {\n            const reason = new Boom(lastDisconnect?.error)?.output?.statusCode;\n            console.log(`\\x1b[31m[ERRO]\\x1b[0m Conexão encerrada. Motivo: ${reason}`);\n            const shouldReconnect = reason !== DisconnectReason.loggedOut;\n            if (shouldReconnect) {\n                console.log(\"\\x1b[33m[SISTEMA]\\x1b[0m Reiniciando em 5 segundos...\");\n                setTimeout(startBot, 5000);\n            } else {\n                console.log(\"\\x1b[31m[ERRO]\\x1b[0m Sessão encerrada. Apague a pasta 'auth_iris' e tente novamente.\");\n            }\n        }\n    });\n\n    sock.ev.on(\"group-participants.update\", async (update) => {\n        const { id, participants, action } = update;\n        if (action === \"add\" && db.groups[id]?.welcome) {\n            const groupMetadata = await sock.groupMetadata(id).catch(() => null);\n            const groupName = groupMetadata?.subject || \"Grupo\";\n            for (const p of participants) {\n                const text = `👋 *BEM-VINDO(A)* @${p.split('@')[0]} ao grupo *${groupName}*!\\n\\nUse *.menu* para ver meus comandos.`;\n                await sock.sendMessage(id, { text, mentions: [p] });\n            }\n        }\n    });\n\n    sock.ev.on(\"messages.upsert\", async ({ messages }) => {\n        for (const msg of messages) {\n            try {\n                if (!msg.message) continue;\n                const from = msg.key.remoteJid;\n                const isGroup = from.endsWith('@g.us');\n                const messageType = Object.keys(msg.message)[0];\n                const msgId = msg.key.id;\n                const sender = msg.key.participant || msg.key.remoteJid;\n\n                // Detecção de Dono Robustizada\n                const isOwner = sender.includes(adminNumber.split('@')[0]) || msg.key.fromMe;\n\n                db.stats.messages++;\n\n                // Cache para Anti-Delete\n                if (messageType !== 'protocolMessage') {\n                    msgCache.set(msgId, msg);\n                    if (msgCache.size > 1000) msgCache.delete(msgCache.keys().next().value);\n                }\n\n                // Anti-Delete\n                if (messageType === 'protocolMessage' && msg.message.protocolMessage?.key) {\n                    await handleAntiDelete(sock, msg);\n                    continue;\n                }\n\n                // Auto Reveal\n                const viewOnce = msg.message?.viewOnceMessageV2?.message || msg.message?.viewOnceMessage?.message;\n                if (viewOnce) await handleAutoReveal(sock, msg, viewOnce);\n\n                // Body extraction\n                const body = (\n                    (messageType === \"conversation\" ? msg.message.conversation :\n                        messageType === \"extendedTextMessage\" ? msg.message.extendedTextMessage?.text :\n                            messageType === \"imageMessage\" ? msg.message.imageMessage?.caption :\n                                messageType === \"videoMessage\" ? msg.message.videoMessage?.caption : \"\") || \"\"\n                ).trim();\n\n                if (!body) continue;\n\n                // XP System\n                if (!db.users[sender]) db.users[sender] = { xp: 0, level: 1, warns: 0, blacklist: false, whitelist: false };\n\n                // Bloqueio Blacklist (Ignora se for Dono ou Whitelist)\n                if (db.users[sender].blacklist && !isOwner && !db.users[sender].whitelist) return;\n\n                db.users[sender].xp += Math.floor(Math.random() * 10) + 5;\n                const nextLevel = db.users[sender].level * 500;\n                if (db.users[sender].xp >= nextLevel) {\n                    db.users[sender].level++;\n                    if (!msg.key.fromMe) await sock.sendMessage(from, { text: `🎉 *PARABÉNS* @${sender.split('@')[0]}! Nível *${db.users[sender].level}*!`, mentions: [sender] });\n                }\n\n                if (isGroup && db.groups[from]?.replies?.[body.toLowerCase()]) {\n                    await sock.sendMessage(from, { text: db.groups[from].replies[body.toLowerCase()] });\n                }\n\n                // Command variables\n                const args = body.split(/ +/);\n                const command = args[0].toLowerCase();\n                const textAfter = body.slice(command.length).trim();\n                const isCmd = body.startsWith(PREFIX);\n                const q = isCmd ? command.slice(PREFIX.length) : command;\n\n                // Permissões\n                const groupMetadata = isGroup ? await sock.groupMetadata(from).catch(() => null) : null;\n                const participants = groupMetadata ? groupMetadata.participants : [];\n                const admins = participants.filter(p => p.admin).map(p => p.id);\n                const isAdmins = admins.includes(sender);\n\n                // Forçamos a detecção do bot como admin usando comparação numérica ultra-robusta\n                const isBotAdmins = admins.map(a => a.split('@')[0].replace(/\\D/g, '')).includes(botNumber.replace(/\\D/g, ''));\n\n                // COMANDOS SEM PREFIXO (MENU/SYSTEM)\n                if (q === \"menu\" || q === \"system\") {\n                    if (q === \"menu\") {\n                        const isPrivate = body.toLowerCase().includes(\"private\");\n                        const isAll = body.toLowerCase().includes(\"all\");\n\n                        if (isPrivate) {\n                            if (!isOwner) {\n                                console.log(`[AUTH] Acesso negado para .menu private por ${sender}`);\n                                return;\n                            }\n                            const uptime = process.uptime();\n                            const h = Math.floor(uptime / 3600);\n                            const m = Math.floor((uptime % 3600) / 60);\n                            const privateMenu = `🔐 *${BOT_NAME} PAINEL DE CONTROLE*\\n\\n` +\n                                `🤖 *Status:* Online\\n` +\n                                `⏳ *Tempo Ativo:* ${h}h ${m}m\\n` +\n                                `📦 *Cache Mídia:* ${msgCache.size}/1000\\n` +\n                                `📊 *Msgs Processadas:* ${db.stats.messages}\\n\\n` +\n                                `🛠️ *CONTROLES TÉCNICOS*\\n` +\n                                `├ .cleancache - Limpa buffer de mídia\\n` +\n                                `├ .vercache - Vê tamanho atual do cache\\n` +\n                                `├ .broadcast [msg] - Aviso para todos grupos\\n` +\n                                `├ .blacklist add [num] - Bloqueia número\\n` +\n                                `├ .whitelist add [num] - Libera número\\n` +\n                                `├ .groups - Lista grupos ativos\\n` +\n                                `├ .log - Vê logs do sistema\\n` +\n                                `└ .memory - Uso de RAM do bot\\n\\n` +\n                                `━━━━━━━━━━━━━━━━━━━`;\n                            return await sock.sendMessage(from, { text: privateMenu });\n                        }\n\n                        if (isAll) {\n                            const allMenu = `📚 *IRIS COMPENDIUM - GUIA COMPLETO*\\n\\n` +\n                                `📸 *REVELAR MÍDIA*\\n` +\n                                `├ *.ver / .explanar* - Use respondendo a uma mídia de visualização única para revelá-la.\\n` +\n                                `├ *kkk / perai* - Atalhos rápidos para o mesmo efeito de revelar mídia.\\n\\n` +\n                                `🔨 *MODERAÇÃO*\\n` +\n                                `├ *.ban* - Remove o usuário marcado ou mencionado do grupo.\\n` +\n                                `├ *.promote* - Torna o usuário mencionado um administrador.\\n` +\n                                `├ *.demote* - Remove o cargo de administrador do usuário mencionado.\\n` +\n                                `├ *.warn* - Aplica uma advertência. No 3º aviso, o usuário é expulso.\\n` +\n                                `├ *.mute / .unmute* - Fecha/abre o grupo para mensagens de membros.\\n` +\n                                `├ *.clear [n]* - Apaga as últimas N mensagens do chat.\\n` +\n                                `└ *.tagall / .hideall* - Marca todos do grupo (visível ou oculto).\\n\\n` +\n                                `⚙️ *CONFIGURAÇÃO ATIVA*\\n` +\n                                `├ *.system config* - Mostra o status atual das travas do grupo.\\n` +\n                                `├ *.antilink on/off* - Bane automaticamente quem enviar link de grupos.\\n` +\n                                `├ *.antimedia on/off* - Apaga automaticamente fotos/vídeos enviados.\\n` +\n                                `├ *.antiflood on/off* - Impede spam de mensagens seguidas.\\n` +\n                                `├ *.welcome on/off* - Boas-vindas automática para novos membros.\\n` +\n                                `└ *.captcha on/off* - Exige verificação para novos membros.\\n\\n` +\n                                `🎭 *INTERAÇÃO & XP*\\n` +\n                                `├ *.addreply [trigger | msg]* - Cria uma resposta automática personalizada.\\n` +\n                                `├ *.delreply [trigger]* - Apaga uma resposta automática existente.\\n` +\n                                `├ *.listreply* - Lista todas as respostas salvas no grupo.\\n` +\n                                `└ *.rank / .level / .xp* - Mostra sua experiência e posição no ranking.\\n\\n` +\n                                `🎰 *UTILITÁRIOS*\\n` +\n                                `├ *.sorteio* - Realiza um sorteio entre os membros do grupo.\\n` +\n                                `└ *.enquete [Título | Opção 1 | Opção 2]* - Cria uma enquete interativa.\\n\\n` +\n                                `━━━━━━━━━━━━━━━━━━━`;\n                            return await sock.sendMessage(from, { text: allMenu });\n                        }\n\n                        const menu = `🚀 *${BOT_NAME} AUTORIDADE* 🚀\\n\\n` +\n                            `📸 *REVELAR MÍDIA*\\n` +\n                            `├ .ver / .explanar \\n` +\n                            `├ kkk / perai\\n\\n` +\n                            `🔨 *MODERAÇÃO*\\n` +\n                            `├ .ban / .promote / .demote\\n` +\n                            `├ .warn / .mute / .unmute\\n` +\n                            `├ .clear [n] / .tagall / .hideall\\n\\n` +\n                            `⚙️ *CONFIGURAÇÃO ATIVA*\\n` +\n                            `├ .system config\\n` +\n                            `├ .antilink / .antiflood\\n` +\n                            `├ .antimedia / .allowlinks\\n` +\n                            `├ .captcha / .welcome / .span\\n\\n` +\n                            `🎭 *INTERAÇÃO & XP*\\n` +\n                            `├ .addreply / .delreply / .listreply\\n` +\n                            `├ .level / .xp / .rank / .mode\\n\\n` +\n                            `🎰 *UTILITÁRIOS*\\n` +\n                            `├ .sorteio / .enquete / .stats\\n` +\n                            `└ .menu private\\n\\n` +\n                            `━━━━━━━━━━━━━━━━━━━`;\n                        return await sock.sendMessage(from, { text: menu });\n                    }\n\n                    if (q === \"system\" && args[1] === \"config\") {\n                        if (!isGroup || (!isAdmins && !isOwner)) return;\n                        if (!db.groups[from]) db.groups[from] = { antilink: false, replies: {} };\n                        const g = db.groups[from];\n                        const cfgTxt = `⚙️ *PAINEL: ${BOT_NAME}*\\n\\n` +\n                            `🔗 *Antilink:* ${g.antilink ? \"✅\" : \"❌\"}\\n` +\n                            `📸 *Antimedia:* ${g.antimedia ? \"✅\" : \"❌\"}\\n` +\n                            `🤝 *Welcome:* ${g.welcome ? \"✅\" : \"❌\"}\\n` +\n                            `🎭 *Modo:* ${g.mode || \"serio\"}\\n\\n` +\n                            `📊 *Membros:* ${participants.length}\\n` +\n                            `🛡️ *Admin Bot:* ${isBotAdmins ? \"✅ Sim\" : \"❌ Não\"}`;\n                        return await sock.sendMessage(from, { text: cfgTxt });\n                    }\n                }\n\n                // REVELAR MÍDIA (KKK, PERAI, VER, EXPLANAR)\n                if ([\"ver\", \"explanar\", \"kkk\", \"perai\"].includes(q)) {\n                    await handleRevealMedia(sock, msg);\n                    continue;\n                }\n\n                // REQUER PREFIXO PARA O RESTO\n                if (!isCmd) continue;\n                db.stats.commands++;\n                addLog(`Cmd: ${command} de ${sender}`);\n\n                // --- COMANDOS COM PREFIXO ---\n                if (q === \"ban\") {\n                    if (!isGroup || (!isAdmins && !isOwner) || !isBotAdmins) return;\n                    const target = msg.message.extendedTextMessage?.contextInfo?.participant || msg.message.extendedTextMessage?.contextInfo?.mentionedJid?.[0];\n                    if (target) await sock.groupParticipantsUpdate(from, [target], \"remove\");\n                }\n                if (q === \"promote\") {\n                    if (!isGroup || (!isAdmins && !isOwner) || !isBotAdmins) return;\n                    const target = msg.message.extendedTextMessage?.contextInfo?.participant || msg.message.extendedTextMessage?.contextInfo?.mentionedJid?.[0];\n                    if (target) await sock.groupParticipantsUpdate(from, [target], \"promote\");\n                }\n                if (q === \"demote\") {\n                    if (!isGroup || (!isAdmins && !isOwner) || !isBotAdmins) return;\n                    const target = msg.message.extendedTextMessage?.contextInfo?.participant || msg.message.extendedTextMessage?.contextInfo?.mentionedJid?.[0];\n                    if (target) await sock.groupParticipantsUpdate(from, [target], \"demote\");\n                }\n                if (q === \"warn\") {\n                    if (!isGroup || (!isAdmins && !isOwner)) return;\n                    const target = msg.message.extendedTextMessage?.contextInfo?.participant || msg.message.extendedTextMessage?.contextInfo?.mentionedJid?.[0];\n                    if (!target) return;\n                    if (!db.users[target]) db.users[target] = { xp: 0, level: 1, warns: 0 };\n                    db.users[target].warns++;\n                    await sock.sendMessage(from, { text: `⚠️ Advertência @${target.split('@')[0]} (${db.users[target].warns}/3)`, mentions: [target] });\n                    if (db.users[target].warns >= 3) {\n                        db.users[target].warns = 0;\n                        if (isBotAdmins) await sock.groupParticipantsUpdate(from, [target], \"remove\");\n                    }\n                }\n                if (q === \"mute\" && isBotAdmins) await sock.groupSettingUpdate(from, 'announcement');\n                if (q === \"unmute\" && isBotAdmins) await sock.groupSettingUpdate(from, 'not_announcement');\n\n                if (q === \"clear\") {\n                    if (!isGroup) return;\n                    if (!isAdmins && !isOwner) return await sock.sendMessage(from, { text: \"❌ Apenas administradores podem usar este comando.\" });\n\n                    // Se não detectou admin mas é o dono, deixamos tentar (o WA vai falhar se realmente não for admin)\n                    if (!isBotAdmins && !isOwner) return await sock.sendMessage(from, { text: \"❌ Eu preciso ser *Administrador* para apagar mensagens de outros membros!\" });\n\n                    const num = parseInt(args[1]) || 10;\n                    if (num > 50) return sock.sendMessage(from, { text: \"❌ Limite de 50 mensagens para sua segurança.\" });\n\n                    const msgs = Array.from(msgCache.values())\n                        .filter(m => m.key.remoteJid === from)\n                        .slice(-(num + 1));\n\n                    if (msgs.length <= 1) return sock.sendMessage(from, { text: \"❌ Não encontrei mensagens recentes no histórico para apagar.\" });\n\n                    const statusMsg = await sock.sendMessage(from, { text: `🧹 Iniciando limpeza de ${msgs.length - 1} mensagens...` });\n\n                    let deletedCount = 0;\n                    for (const m of msgs) {\n                        try {\n                            await sock.sendMessage(from, { delete: m.key });\n                            deletedCount++;\n                            await delay(1000); // 1 segundo para segurança\n                        } catch (e) {\n                            console.log(\"Falha ao apagar:\", e.message);\n                        }\n                    }\n\n                    // Apaga o aviso de início se possível\n                    try { await sock.sendMessage(from, { delete: statusMsg.key }); } catch (e) { }\n                    return;\n                }\n\n                if (q === \"tagall\" || q === \"hideall\") {\n                    if (!isGroup || (!isAdmins && !isOwner)) return;\n                    const jids = participants.map(p => p.id);\n                    await sock.sendMessage(from, { text: `📢 *CHAMADA GERAL*\\n\\n` + (q === \"tagall\" ? jids.map(j => `@${j.split('@')[0]}`).join(\" \") : \"\"), mentions: jids });\n                }\n\n                if ([\"antilink\", \"antiflood\", \"antimedia\", \"captcha\", \"welcome\", \"span\"].includes(q)) {\n                    if (!isGroup || (!isAdmins && !isOwner)) return;\n                    if (!db.groups[from]) db.groups[from] = { antilink: false, replies: {} };\n                    const state = args[1] === \"on\";\n                    db.groups[from][q] = state;\n                    await sock.sendMessage(from, { text: `🛡️ *${q.toUpperCase()}*: ${state ? \"ON\" : \"OFF\"}` });\n                }\n\n                if (q === \"system\" && args[1] === \"config\") {\n                    if (!isGroup || (!isAdmins && !isOwner)) return;\n                    const g = db.groups[from] || {};\n                    const cfgTxt = `⚙️ *PAINEL DE CONTROLE - ${BOT_NAME}*\\n\\n` +\n                        `🔗 *Antilink:* ${g.antilink ? \"✅ Ligado\" : \"❌ Desligado\"}\\n` +\n                        `🌊 *Antiflood:* ${g.antiflood ? \"✅ Ligado\" : \"❌ Desligado\"}\\n` +\n                        `📸 *Antimedia:* ${g.antimedia ? \"✅ Ligado\" : \"❌ Desligado\"}\\n` +\n                        `🤝 *Welcome:* ${g.welcome ? \"✅ Ligado\" : \"❌ Desligado\"}\\n` +\n                        `🧩 *Captcha:* ${g.captcha ? \"✅ Ligado\" : \"❌ Desligado\"}\\n` +\n                        `⏰ *Span:* ${g.span ? \"✅ Ligado\" : \"❌ Desligado\"}\\n` +\n                        `🎭 *Modo:* ${g.mode || \"serio\"}\\n\\n` +\n                        `📊 *Membros:* ${participants.length}\\n` +\n                        `🛡️ *Admin Bot:* ${isBotAdmins ? \"✅ Sim\" : \"❌ Não\"}\\n\\n` +\n                        `💡 _Para alterar use .[comando] on/off_`;\n                    return await sock.sendMessage(from, { text: cfgTxt });\n                }\n\n                if (q === \"addreply\") {\n                    if (!isGroup || (!isAdmins && !isOwner)) return;\n                    if (!db.groups[from]) db.groups[from] = { replies: {} };\n                    const parts = textAfter.split(\"|\");\n                    if (parts.length < 2) return await sock.sendMessage(from, { text: \"❌ Use: .addreply gatilho | resposta\" });\n                    db.groups[from].replies[parts[0].trim().toLowerCase()] = parts[1].trim();\n                    await sock.sendMessage(from, { text: \"✅ Resposta cadastrada com sucesso!\" });\n                }\n\n                if (q === \"delreply\") {\n                    if (!isGroup || (!isAdmins && !isOwner)) return;\n                    if (!db.groups[from]?.replies) return await sock.sendMessage(from, { text: \"❌ Nenhuma resposta cadastrada neste grupo.\" });\n                    const trigger = textAfter.trim().toLowerCase();\n                    if (!db.groups[from].replies[trigger]) return await sock.sendMessage(from, { text: \"❌ Gatilho não encontrado.\" });\n                    delete db.groups[from].replies[trigger];\n                    await sock.sendMessage(from, { text: `🗑️ Resposta para \"${trigger}\" removida!` });\n                }\n\n                if (q === \"listreply\") {\n                    if (!isGroup) return;\n                    const replies = Object.keys(db.groups[from]?.replies || {});\n                    if (replies.length === 0) return await sock.sendMessage(from, { text: \"❌ Nenhuma resposta cadastrada neste grupo.\" });\n                    await sock.sendMessage(from, { text: `📋 *RESPOSTAS DO GRUPO*\\n\\n${replies.join(\"\\n\")}` });\n                }\n\n                if (q === \"level\" || q === \"xp\") {\n                    const u = db.users[sender];\n                    await sock.sendMessage(from, { text: `📊 Lvl: ${u.level} | XP: ${u.xp}` });\n                }\n\n                if (q === \"sorteio\") {\n                    const win = participants[Math.floor(Math.random() * participants.length)].id;\n                    await sock.sendMessage(from, { text: `🎉 Ganhador: @${win.split('@')[0]}`, mentions: [win] });\n                }\n\n                if (q === \"rank\") {\n                    const sorted = Object.entries(db.users)